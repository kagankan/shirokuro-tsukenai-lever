{
  "name": "shirokuro-tsukenai-lever",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "panda codegen",
    "gen:types": "SUPABASE_ACCESS_TOKEN=\"$(pass show supabase/access-token)\" supabase gen types typescript --project-id vsqgixmesuaabifdbbra --schema public > src/lib/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@pandacss/dev": "^1.10.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "supabase": "^2.95.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "supabase"
    ]
  }
}
