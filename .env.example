# Supabase プロジェクトの接続情報
# ダッシュボードの Project Settings > API Keys から取得して .env にコピーしてください。
# この2つはフロントエンドにバンドルされる公開情報で、機密ではありません（RLS で保護）。
# Publishable key が新しい標準ではあるが、Realtime（WebSocket）はanon key（JWT形式、eyJ...）が必要。

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
