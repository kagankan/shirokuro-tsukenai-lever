# Supabase プロジェクトの接続情報
# ダッシュボードの Project Settings > API Keys から取得して .env にコピーしてください。
# この2つはフロントエンドにバンドルされる公開情報で、機密ではありません（RLS で保護）。
# Publishable key が新しい標準（旧 anon key は legacy 扱い）。

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
